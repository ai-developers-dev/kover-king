# Turso Database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Anthropic (optional - for AI features)
ANTHROPIC_API_KEY=your-key

# AI blog generation (admin "Generate with AI" button)
OPENAI_API_KEY=your-openai-key
TAVILY_API_KEY=your-tavily-key

# Author photo uploads (Vercel Blob). Auto-injected in Vercel once a Blob
# store is created; needed locally to test photo uploads.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Meta Lead Ads Webhook
META_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-page-access-token

# Weekly SEO keyword-idea email (Resend). Verify koverking.com in Resend so
# EMAIL_FROM can send from your domain. CRON_SECRET protects the cron endpoint
# (Vercel Cron sends it automatically as a Bearer token).
RESEND_API_KEY=your-resend-key
EMAIL_FROM=Kover King SEO <seo@koverking.com>
EMAIL_TO=doug@aideveloper.dev
CRON_SECRET=your-long-random-secret

# Analytics & verification (optional; no-op until set)
VITE_GA_ID=G-XXXXXXXXXX
VITE_GSC_VERIFICATION=your-search-console-token
